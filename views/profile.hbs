<div class='w-[75%] mx-auto px-6 mt-12'>
  {{#if (eq type 'file')}}
    <div class='flex flex-row gap-8'>
      <div class='w-1/3'>
        {{#if imagePath}}
          <div class='bg-white p-6 rounded-xl shadow-sm border border-gray-200'>
            <div class='relative mb-4'>
              <img
                src='{{imagePath}}'
                alt='{{name}}'
                class='w-full aspect-square object-cover rounded-lg'
              />
              <div
                class='absolute top-2 right-2 bg-gray-800 text-white px-3 py-1 rounded-full text-sm'
              >
                <span>Student</span>
              </div>
            </div>

            <div class='flex justify-between py-2'>
              <span class='text-gray-500'>Progress</span>
              <span class='font-medium'>Just Started</span>
            </div>
          </div>
        {{/if}}
      </div>

      <div class='w-2/3'>
        <div class='mb-8 text-left'>
          <h1 class='font-serif text-4xl font-bold mb-2'>Welcome,
            {{name}}! 👋</h1>
          <p class='text-gray-500 italic text-lg'>{{message}}</p>
        </div>

        <div>
          <div
            class='bg-white p-6 rounded-xl shadow-sm border border-gray-200 mb-6'
          >
            <h2 class='font-serif text-xl font-bold mb-6'>📋 Profile Information</h2>

            <div class='space-y-4'>
              <div class='flex'>
                <span class='w-32 text-gray-500'>Full Name</span>
                <span class='font-medium'>{{name}}</span>
              </div>

              <div class='flex'>
                <span class='w-32 text-gray-500'>Email Address</span>
                <span class='font-medium'>{{email}}</span>
              </div>

              <div class='flex items-center'>
                <span class='w-32 text-gray-500'>Course Track</span>
                <span
                  class='font-medium px-3 py-1 bg-yellow-200 rounded-full text-sm'
                >{{course}}</span>
              </div>
            </div>
          </div>

          <div
            class='bg-white p-6 rounded-xl shadow-sm border border-gray-200 mb-6'
          >
            <h2 class='font-bold text-xl'>📁 File Information</h2>
            <div class='mt-4 space-y-6 text-sm'>
              <div>
                <span class='text-gray-500'>Image Path:</span>
                <span
                  class='font-mono block mt-1 p-2 bg-gray-50 rounded'
                >{{imagePath}}</span>
              </div>
              <div>
                <span class='text-gray-500'>Original Filename:</span>
                <span class='block mt-2'>{{originalFileName}}</span>
              </div>
            </div>
          </div>

          <!-- Action Button -->
          <div class='flex flex-wrap gap-3'>
            <a
              href='/'
              class='px-6 py-3 border border-gray-300 rounded-lg font-medium hover:bg-gray-100 transition no-underline text-gray-800 inline-block'
            >← Go Back to Homepage</a>
          </div>
        </div>
      </div>
    </div>
  {{/if}}
</div>